        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "dimension": {
            "type": [
              "null",
              "string"
            ]
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "integer"
          },
          "employeeId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "parentId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        },
        "additionalProperties": false,
        "required": [
          "name",
          "startDate",
          "endDate",
          "status"
        ]
      }
    },
