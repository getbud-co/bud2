@if (IsLoading)
{
    <div class="paged-section">
        <div class="paged-section-state paged-section-loading">
            <p class="muted">@LoadingText</p>
        </div>
    </div>
}
else if (IsEmpty)
{
    <div class="paged-section">
        <div class="paged-section-state paged-section-empty">
            <p class="muted">@EmptyText</p>
        </div>
    </div>
}
else
{
    <div class="paged-section">
        @ChildContent
        <div class="paged-section-meta">Total: @Total</div>
    </div>
}
