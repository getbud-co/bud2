@page "/goals"
@inject ApiClient Api
@inject OrganizationContext OrgContext
@inject AuthState AuthState
@inject ToastService ToastService
@inject UiOperationService UiOps
@implements IDisposable

<div class="goals-page">
<ManagementPageHeader
    Kicker="Performance e engajamento"
    Title="Metas"
    Subtitle="Organize objetivos, acompanhe indicadores e mantenha o ciclo de check-ins no ritmo certo."
    PrimaryActionText="Criar meta"
    OnPrimaryAction="OpenCreateModal" />

<GoalsFilterBar Filter="_filter"
                FilterActiveOnly="_filterActiveOnly"
                FilterStartDate="_filterStartDate"
                FilterEndDate="_filterEndDate"
                Search="@_search"
                OnSetFilter="SetGoalFilter"
                OnToggleActiveFilter="HandleToggleActiveFilter"
                OnDateFilterApplied="HandleDateFilterApplied"
                OnSearchSubmit="HandleSearchSubmit"
                OnClearFilters="HandleClearFilters" />

<div class="goals-action-bar">
    @if (_viewMode == "kanban")
    {
        <button class="filter-chip @(_kanbanShowArchived ? "active" : "")" title="Mostrar arquivados" @onclick="HandleToggleKanbanArchived">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/>
            </svg>
        </button>
    }
    <button class="filter-chip" @onclick="HandleToggleViewMode">
        @if (_viewMode == "list")
        {
            <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
                <path d="M4 8H28M4 16H28M4 24H28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span>Vendo em lista</span>
        }
        else if (_viewMode == "grid")
        {
            <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
                <rect x="4" y="6" width="8" height="8" rx="1" stroke="currentColor" stroke-width="2"/>
                <rect x="4" y="18" width="8" height="8" rx="1" stroke="currentColor" stroke-width="2"/>
                <rect x="20" y="6" width="8" height="8" rx="1" stroke="currentColor" stroke-width="2"/>
                <rect x="20" y="18" width="8" height="8" rx="1" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>Vendo em cartões</span>
        }
        else
        {
            <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
                <rect x="4" y="4" width="7" height="24" rx="1" stroke="currentColor" stroke-width="2"/>
                <rect x="13" y="4" width="7" height="24" rx="1" stroke="currentColor" stroke-width="2"/>
                <rect x="22" y="4" width="7" height="24" rx="1" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>Vendo em kanban</span>
        }
    </button>
</div>

@* Cards de Resumo *@
<SummaryCards CssClass="goals-summary">
    <StatCard Value="@($"{GetOverallProgressDisplay()}%")" Label="@($"Esperado {GetExpectedProgressDisplay()}%")" ShowProgress="true" Progress="GetOverallProgressDisplay()" ExpectedProgress="GetExpectedProgressDisplay()" />
    <StatCard Value="@GetActiveGoalsCount().ToString()" Label="Metas ativas" />
    <StatCard Value="@GetOutdatedIndicatorsCount().ToString()" Label="Indicadores desatualizados" />
</SummaryCards>

@* Lista de Metas em Cards *@
@if (_goals is null)
{
    <div class="goals-loading">
        <p class="muted">Carregando...</p>
    </div>
}
else if (_goals.Items.Count == 0)
{
    <div class="goals-empty">
        <div class="goals-empty-icon">📋</div>
        <p class="muted">Nenhuma meta encontrada.</p>
    </div>
}
else
{
    @if (_viewMode == "grid")
    {
        <GoalGridView @key="_cardRefreshToken"
                      RootGoals="_goals"
                      RootGoalProgress="_goalProgress"
                      Collaborators="_collaborators"
                      DeletingGoalId="_deletingGoalId"
                      OnEdit="async (goal) => await OpenEditWizard(goal)"
                      OnDeleteClick="(id) => HandleDeleteClick(id)"
                      OnCheckinClick="t => OpenCheckinModalForIndicator(t.goal, t.indicator)"
                      OnHistoryClick="t => OpenCheckinHistoryModal(t.goal, t.indicator)" />
    }
    else if (_viewMode == "kanban")
    {
        <GoalKanbanView Tasks="_kanbanAllTasks"
                        Goals="_kanbanAllGoals"
                        ShowArchived="_kanbanShowArchived"
                        OnTaskStateChange="HandleKanbanTaskStateChange" />
    }
    else
    {
        <div class="goals-list">
            @foreach (var goal in _goals.Items)
            {
                <GoalCard @key="@($"{goal.Id}-{_cardRefreshToken}")" Goal="goal"
                          Progress="@(_goalProgress.GetValueOrDefault(goal.Id))"
                          IsExpanded="@(_expandedGoals.Contains(goal.Id))"
                          IsDeleting="@(_deletingGoalId == goal.Id)"
                          Indicators="@(_goalIndicatorsCache.GetValueOrDefault(goal.Id))"
                          Tasks="@(_goalTasksCache.GetValueOrDefault(goal.Id))"
                          ChildGoals="@(_goalChildrenCache.GetValueOrDefault(goal.Id))"
                          IndicatorProgressCache="_indicatorProgressCache"
                          GoalProgressCache="_childGoalProgressCache"
                          ExpandedGoals="_expandedChildGoals"
                          OnToggleExpand="async () => await ToggleExpand(goal.Id)"
                          OnEdit="async () => await OpenEditWizard(goal)"
                          OnDeleteClick="() => HandleDeleteClick(goal.Id)"
                          OnToggleGoalExpand="ToggleChildGoalExpand"
                          OnExpandModal="async (g) => await OpenDetailModal(g)"
                          OnCheckinClick="m => OpenCheckinModalForIndicator(goal, m)"
                          OnHistoryClick="m => OpenCheckinHistoryModal(goal, m)"
                          OnTaskStateChange="t => HandleTaskStateChange(goal.Id, t.task, t.newState)" />
            }
        </div>
    }
    <p class="muted" style="margin-top: var(--spacing-4);">Total: @_goals.Total</p>
}

<GoalFormModal IsOpen="_isWizardOpen"
               IsEditMode="_isEditMode"
               OrganizationName="@GetSelectedOrganizationName()"
               InitialModel="_wizardInitialModel"
               Templates="_availableTemplates"
               CollaboratorOptions="GetCollaboratorOptions()"
               OnClose="CloseWizard"
               OnSave="HandleWizardSave"
               OnSaveDraft="HandleWizardSaveDraft" />


<CheckinModal IsOpen="@(_isCheckinModalOpen && _selectedCheckinIndicator != null)"
              Indicator="_selectedCheckinIndicator"
              OnClose="CloseCheckinModal"
              OnSubmit="HandleCheckinSubmit" />

<CheckinHistoryModal IsOpen="@(_isCheckinHistoryModalOpen && _historyIndicator != null)"
                     Indicator="_historyIndicator"
                     Checkins="_indicatorCheckins"
                     IsLoading="_isLoadingCheckins"
                     OnClose="CloseCheckinHistoryModal"
                     OnNewCheckin="OpenCheckinFromHistory" />

<GoalDetailModal IsOpen="_isDetailModalOpen"
                 Goal="_detailModalGoal"
                 Progress="@(_detailModalGoal != null ? _goalProgress.GetValueOrDefault(_detailModalGoal.Id) : null)"
                 ParentName="@GetDetailModalParentName()"
                 Indicators="@(_detailModalGoal != null ? _goalIndicatorsCache.GetValueOrDefault(_detailModalGoal.Id) : null)"
                 Tasks="@(_detailModalGoal != null ? _goalTasksCache.GetValueOrDefault(_detailModalGoal.Id) : null)"
                 ChildGoals="@(_detailModalGoal != null ? _goalChildrenCache.GetValueOrDefault(_detailModalGoal.Id) : null)"
                 IndicatorProgressCache="_indicatorProgressCache"
                 GoalProgressCache="_childGoalProgressCache"
                 OnClose="CloseDetailModal"
                 OnEdit="async () => { CloseDetailModal(); if (_detailModalGoal != null) await OpenEditWizard(_detailModalGoal); }"
                 OnCheckinClick="m => { if (_detailModalGoal != null) OpenCheckinModalForIndicator(_detailModalGoal, m); }"
                 OnHistoryClick="async m => { if (_detailModalGoal != null) await OpenCheckinHistoryModal(_detailModalGoal, m); }"
                 OnTaskStateChange="async t => { if (_detailModalGoal != null) await HandleTaskStateChange(_detailModalGoal.Id, t.task, t.newState); }" />
</div>
