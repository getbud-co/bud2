
<div class="kanban-board @(_draggingTask != null ? "kanban-dragging" : "")">
    @foreach (var column in _columns)
    {
        @if (!ShowArchived && column.State == TaskState.Archived)
        {
            continue;
        }

        var columnTasks = Tasks.Where(t => t.State == column.State).ToList();

        <div class="kanban-column @column.CssClass">
            <div class="kanban-column-header @column.CssClass">
                <span class="kanban-column-title">@column.Label</span>
                <span class="kanban-column-count">@columnTasks.Count</span>
            </div>
            <div class="kanban-column-body @(_dropTargetColumn == column.State ? "kanban-drop-target" : "")"
                 @ondragover:preventDefault="true"
                 @ondragenter="@(() => HandleDragEnter(column.State))"
                 @ondrop="@(() => HandleDrop(column.State))">
                @foreach (var task in columnTasks)
                {
                    var goalName = Goals.FirstOrDefault(g => g.Id == task.GoalId)?.Name;
                    <div class="kanban-card @(_draggingTask?.Id == task.Id ? "kanban-card-dragging" : "")"
                         draggable="true"
                         @ondragstart="@(() => HandleDragStart(task))"
                         @ondragend="HandleDragEnd">
                        @if (goalName is not null)
                        {
                            <span class="kanban-card-goal">@goalName</span>
                        }
                        <div class="kanban-card-name @(task.State == TaskState.Done || task.State == TaskState.Archived ? "task-done" : "")">
                            @task.Name
                        </div>
                        @if (!string.IsNullOrWhiteSpace(task.Description))
                        {
                            <div class="kanban-card-description">@task.Description</div>
                        }
                        @if (task.DueDate.HasValue && task.State != TaskState.Done && task.State != TaskState.Archived)
                        {
                            <span class="kanban-card-due @GetDueDateClass(task)">@FormatDueDate(task)</span>
                        }
                    </div>
                }
                @if (columnTasks.Count == 0)
                {
                    <div class="kanban-column-empty">Nenhuma tarefa</div>
                }
            </div>
        </div>
    }
</div>

