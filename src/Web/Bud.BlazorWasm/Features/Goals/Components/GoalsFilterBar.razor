
@* Barra de Filtros Compacta *@
<div class="goals-filter-bar">
    <div class="goals-filter-left">
        @* Mais filtros (status) *@
        <div class="filter-chip-wrapper">
            <button class="filter-chip @(FilterActiveOnly ? "active" : "")" @onclick="ToggleStatusDropdown">
                <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
                    <path d="M4 8H28M8 16H24M12 24H20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>Mais filtros</span>
            </button>
            @if (showStatusDropdown)
            {
                <div class="filter-dropdown">
                    <div class="filter-dropdown-row">
                        <label>Status</label>
                        <button class="filter-dropdown-option @(FilterActiveOnly ? "active" : "")" @onclick="HandleToggleActive">
                            @(FilterActiveOnly ? "Mostrando apenas ativos" : "Mostrando todos os status")
                        </button>
                    </div>
                </div>
            }
        </div>

        @* Filtro de escopo (Mine/MyTeam/All) como dropdown chip *@
        <div class="filter-chip-wrapper">
            <button class="filter-chip active" @onclick="ToggleScopeDropdown">
                <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
                    <path d="M22 28V26C22 23.7909 20.2091 22 18 22H14C11.7909 22 10 23.7909 10 26V28" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="16" cy="14" r="4" stroke="currentColor" stroke-width="2"/>
                    <path d="M28 28V26C28 24.4087 27.1046 23.0131 25.7906 22.2537" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M22 6.25366C23.3141 7.01308 24 8.40872 24 10C24 11.5913 23.3141 12.9869 22 13.7463" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>@GetScopeLabel()</span>
                <svg width="14" height="14" viewBox="0 0 32 32" fill="none">
                    <path d="M8 12L16 20L24 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
            @if (showScopeDropdown)
            {
                <div class="filter-dropdown">
                    <button class="filter-dropdown-option @(Filter == GoalFilter.Mine ? "active" : "")" @onclick="() => SelectScope(GoalFilter.Mine)">
                        Minhas metas
                    </button>
                    <button class="filter-dropdown-option @(Filter == GoalFilter.MyTeam ? "active" : "")" @onclick="() => SelectScope(GoalFilter.MyTeam)">
                        Metas do time
                    </button>
                    <button class="filter-dropdown-option @(Filter == GoalFilter.All ? "active" : "")" @onclick="() => SelectScope(GoalFilter.All)">
                        Todas as metas
                    </button>
                </div>
            }
        </div>

        @* Filtro de data *@
        <div class="filter-chip-wrapper">
            <button class="filter-chip @(FilterStartDate.HasValue || FilterEndDate.HasValue ? "active" : "")" @onclick="ToggleDatePicker">
                <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
                    <path d="M26 4H6C4.89543 4 4 4.89543 4 6V26C4 27.1046 4.89543 28 6 28H26C27.1046 28 28 27.1046 28 26V6C28 4.89543 27.1046 4 26 4Z" stroke="currentColor" stroke-width="2"/>
                    <path d="M22 2V6M10 2V6M4 12H28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>@GetDateRangeLabel()</span>
                <svg width="14" height="14" viewBox="0 0 32 32" fill="none">
                    <path d="M8 12L16 20L24 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
            @if (showDatePicker)
            {
                <div class="filter-dropdown">
                    <div class="filter-dropdown-row">
                        <label>Data inicial</label>
                        <input type="date" class="input" value="@localStartDate?.ToString("yyyy-MM-dd")" @onchange="OnStartDateChanged" />
                    </div>
                    <div class="filter-dropdown-row">
                        <label>Data final</label>
                        <input type="date" class="input" value="@localEndDate?.ToString("yyyy-MM-dd")" @onchange="OnEndDateChanged" />
                    </div>
                    <button class="button small" @onclick="ApplyDateFilter">Aplicar</button>
                </div>
            }
        </div>
    </div>
    <div class="goals-filter-right">
        @if (HasActiveFilters())
        {
            <button class="filter-chip-clear" @onclick="HandleClearFilters">
                <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
                    <path d="M26 16L22 12M22 12L18 8M22 12L26 8M22 12L18 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M6 8L10 28H14L12 18L6 8Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Limpar filtro</span>
            </button>
        }
    </div>
</div>

