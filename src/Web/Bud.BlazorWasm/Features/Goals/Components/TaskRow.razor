
<div class="task-row @GetDueDateRowCssClass()">
    <button class="task-state-btn @GetStateCssClass()" @onclick="OnStateButtonClick" @onclick:stopPropagation="true" title="@GetStateLabel()">
        @if (Task.State == TaskState.Done)
        {
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
        }
        else if (Task.State == TaskState.Doing)
        {
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="8"/>
            </svg>
        }
        else if (Task.State == TaskState.Archived)
        {
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/>
            </svg>
        }
        else
        {
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            </svg>
        }
    </button>
    <div class="task-row-body">
        <div class="task-row-name @(Task.State == TaskState.Done || Task.State == TaskState.Archived ? "task-done" : "")">@Task.Name</div>
        @if (!string.IsNullOrWhiteSpace(Task.Description))
        {
            <div class="task-row-description">@Task.Description</div>
        }
    </div>
    @if (Task.DueDate.HasValue && Task.State != TaskState.Done && Task.State != TaskState.Archived)
    {
        <span class="task-due-chip @GetDueDateChipCssClass()">@FormatDueDate()</span>
    }
    <span class="task-state-badge @GetStateCssClass()">@GetStateLabel()</span>
    @if (ShowDeleteButton)
    {
        <button class="task-action-btn" @onclick="() => OnDelete.InvokeAsync(Task)" @onclick:stopPropagation="true" title="Excluir tarefa">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/>
            </svg>
        </button>
    }
</div>

