@if (!Hidden)
{
    <div class="wizard-step-indicator">
        @foreach (var step in Steps)
        {
            var isActive = step.Value == CurrentStep;
            var isCompleted = step.Value < CurrentStep;
            var css = "wizard-step-item"
                + (isActive ? " wizard-step-item--active" : "")
                + (isCompleted ? " wizard-step-item--completed" : "");

            @if (isCompleted)
            {
                <span class="@css" @onclick="() => OnStepClick.InvokeAsync(step.Value)">@step.Label</span>
            }
            else
            {
                <span class="@css">@step.Label</span>
            }

            @if (step.Value != WizardStep.Review)
            {
                <span class="wizard-step-separator">&gt;</span>
            }
        }
    </div>
}

