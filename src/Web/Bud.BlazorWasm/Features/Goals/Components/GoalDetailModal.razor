
@if (IsOpen && Goal != null)
{
    <div class="goal-detail-backdrop" @onclick="() => OnClose.InvokeAsync()"></div>
    <div class="goal-detail-modal">
        @* Header: Breadcrumb + Actions *@
        <div class="goal-detail-header">
            <div class="goal-detail-breadcrumb">
                @if (!string.IsNullOrWhiteSpace(ParentName))
                {
                    <div class="goal-detail-breadcrumb-parent">
                        <span class="goal-detail-parent-name">@ParentName</span>
                    </div>
                    <svg width="12" height="12" viewBox="0 0 32 32" fill="none" style="color: var(--neutral-400);">
                        <path d="M12 8L20 16L12 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                }
                <span class="goal-detail-breadcrumb-current">@Goal.Name</span>
            </div>
            <div class="goal-detail-header-actions">
                <button class="goal-action-btn" @onclick="() => OnClose.InvokeAsync()" title="Fechar">
                    <svg width="18" height="18" viewBox="0 0 32 32" fill="none">
                        <path d="M8 8L24 24M24 8L8 24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </button>
            </div>
        </div>

        @* Card content - same layout as inline expanded *@
        <div class="goal-detail-content">
            @{
                var progressPercent = (int)(Progress?.OverallProgress ?? 0);
                var circumference = 2 * Math.PI * 19;
                var dashOffset = circumference - (circumference * progressPercent / 100);
            }

            @* Mission header *@
            <div class="goal-card-header" style="cursor: default;">
                <div class="goal-progress-circle">
                    <svg width="44" height="44" viewBox="0 0 44 44">
                        <circle class="progress-bg" cx="22" cy="22" r="19" />
                        @if (Goal.Status != GoalStatus.Planned)
                        {
                            <circle class="progress-value @GoalProgressDisplayHelper.GetGoalProgressStatusClass(Progress)"
                                    cx="22" cy="22" r="19"
                                    stroke-dasharray="@circumference.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                    stroke-dashoffset="@dashOffset.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" />
                        }
                    </svg>
                    <div class="goal-progress-text">
                        <span class="goal-progress-number">@(Goal.Status == GoalStatus.Planned ? "00" : progressPercent.ToString())</span>
                        <span class="goal-progress-percent">%</span>
                    </div>
                </div>
                <div class="goal-card-title-wrapper">
                    <div class="goal-card-title">@Goal.Name</div>
                </div>
            </div>

            @* Expanded content with indicators *@
            <div class="goal-card-content" style="display: flex; flex-direction: column; gap: var(--spacing-2);">
                @if (Indicators is null)
                {
                    <p class="muted">Carregando...</p>
                }
                else
                {
                    var directIndicators = Indicators.Where(m => m.GoalId == Goal.Id).ToList();

                    if (directIndicators.Count > 0)
                    {
                        foreach (var indicator in directIndicators)
                        {
                            <IndicatorRow Goal="Goal"
                                          Indicator="indicator"
                                          GoalProgressResponse="Progress"
                                          IndicatorProgressResponse="@(IndicatorProgressCache.GetValueOrDefault(indicator.Id))"
                                          OnCheckinClick="OnCheckinClick"
                                          OnHistoryClick="OnHistoryClick" />
                        }
                    }

                    if (ChildGoals != null && ChildGoals.Count > 0)
                    {
                        foreach (var childGoal in ChildGoals)
                        {
                            <GoalChildSection ChildGoal="childGoal"
                                              GoalProgressResponse="@(GoalProgressCache.GetValueOrDefault(childGoal.Id))"
                                              IsExpanded="@(_expandedGoals.Contains(childGoal.Id))"
                                              OnToggleExpand="() => ToggleGoalExpand(childGoal.Id)"
                                              Depth="0"
                                              OnCheckinClick="OnCheckinClick"
                                              OnHistoryClick="OnHistoryClick"
                                              OnExpandModal="HandleChildExpandModal" />
                        }
                    }

                    if (Tasks != null && Tasks.Count > 0)
                    {
                        <div class="goal-tasks-section">
                            @foreach (var task in Tasks)
                            {
                                <TaskRow Task="task"
                                         ShowDeleteButton="false"
                                         OnStateChange="async s => await OnTaskStateChange.InvokeAsync((task, s))" />
                            }
                        </div>
                    }

                    if (directIndicators.Count == 0 && (ChildGoals == null || ChildGoals.Count == 0) && (Tasks == null || Tasks.Count == 0))
                    {
                        <p class="muted">Nenhum indicador, tarefa ou meta associada a esta missão.</p>
                    }
                }
            </div>
        </div>
    </div>
}

