# syntax=docker/dockerfile:1.7

ARG DOTNET_SDK_VERSION=10.0.201

FROM mcr.microsoft.com/dotnet/sdk:${DOTNET_SDK_VERSION} AS source
WORKDIR /src
COPY global.json ./
COPY Directory.Build.props ./
COPY src/ ./src/

FROM source AS publish-api
RUN dotnet publish src/Api/Bud.Api/Bud.Api.csproj -c Release -o /app/publish

FROM source AS publish-web
RUN dotnet publish src/Web/Bud.BlazorWasm/Bud.BlazorWasm.csproj -c Release -o /app/publish

FROM source AS publish-mcp
RUN dotnet publish src/Mcp/Bud.Mcp/Bud.Mcp.csproj -c Release -o /app/publish

FROM source AS build-migrate
RUN dotnet restore src/Api/Bud.Api/Bud.Api.csproj
RUN dotnet tool install --tool-path /tools dotnet-ef --version 10.0.2
RUN /tools/dotnet-ef migrations bundle --project src/Server/Bud.Infrastructure --startup-project src/Server/Bud.Api -o /app/efbundle --self-contained

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS prod-migrate
WORKDIR /app
COPY --from=build-migrate /app/efbundle .
COPY --from=publish-api /app/publish/appsettings.json .
COPY --from=publish-api /app/publish/appsettings.Production.json .
ENTRYPOINT ["./efbundle"]

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS prod-api
WORKDIR /app
COPY --from=publish-api /app/publish .
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "Bud.Api.dll"]

FROM nginx:1.27-alpine AS prod-web
COPY src/Web/Bud.BlazorWasm/Hosting/nginx.conf.template /etc/nginx/templates/default.conf.template
COPY --from=publish-web /app/publish/wwwroot /usr/share/nginx/html
ENV BUD_API_BASE_URL=http://bud-api:8080
EXPOSE 8080

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS prod-mcp
WORKDIR /app
COPY --from=publish-mcp /app/publish .
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "Bud.Mcp.dll"]
