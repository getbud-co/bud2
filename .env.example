# Copy this file to .env.gcp and adjust values for your environment.
PROJECT_ID="bud2-spike"
REGION="us-central1"

# Bootstrap (first-time setup)
DB_PASS="your-strong-db-password"
JWT_KEY="your-jwt-key-with-at-least-32-characters"

# Optional defaults
REPO_NAME="bud"
WEB_SERVICE_NAME="bud-web"
API_SERVICE_NAME="bud-api"
MCP_SERVICE_NAME="bud-mcp"
SQL_INSTANCE="bud-pg"
DB_NAME="bud"
DB_USER="bud_app"
SERVICE_ACCOUNT="bud-runner"
# Optional: if empty, bootstrap generates from PROJECT_ID
SECRET_DB_CONNECTION=""
SECRET_JWT_KEY=""

# Observability (OpenTelemetry — used by deploy scripts for GCP production)
# Leave empty for local development (OTLP exporter will fail silently without an endpoint)
OTEL_EXPORTER_OTLP_ENDPOINT="https://telemetry.googleapis.com"
